/* Dashboard layout: single column, vertical stack */
Screen {
    layout: vertical;
}

/* Header: 1 row */
DashboardHeader {
    height: 1;
    padding: 0 1;
    background: $surface;
}

/* Separators */
.dashboard-sep {
    height: 1;
    padding: 0 1;
    color: $text-muted;
}

/* ========================================================= */
/* Violations feed                                            */
/* ========================================================= */

ViolationsFeed {
    height: auto;
    max-height: 24;
}

ViolationsFeed #violations-header {
    height: 1;
    padding: 0 1;
}

ViolationsFeed #violations-container {
    height: auto;
    max-height: 22;
    scrollbar-size: 0 0;
}

ViolationsFeed .violation-row {
    height: 1;
    padding: 0 1;
}

ViolationsFeed .violation-row.--selected {
    background: $primary 12%;
}

ViolationsFeed .violation-detail {
    height: 1;
    padding: 0 1;
    background: $primary 5%;
}

ViolationsFeed .section-label {
    height: 1;
    padding: 0 1;
}

ViolationsFeed .view-all-row {
    height: 1;
    padding: 0 1;
}

/* ========================================================= */
/* Agents feed                                                */
/* ========================================================= */

AgentsFeed {
    height: 1fr;
}

AgentsFeed #agents-header {
    height: 1;
    padding: 0 1;
}

AgentsFeed #agent-filter {
    height: 1;
    padding: 0 1;
    display: none;
    border: none;
    background: $surface;
    color: $primary;
}

AgentsFeed #agent-filter:focus {
    border: none;
}

AgentsFeed #agents-container {
    height: 1fr;
    scrollbar-size: 0 0;
}

AgentsFeed .agent-row {
    height: 1;
    padding: 0 1;
}

AgentsFeed .agent-row.--selected {
    background: $primary 12%;
}

AgentsFeed .agent-row.--problematic {
    background: $error 8%;
}

AgentsFeed .agent-row.--selected.--problematic {
    background: $error 15%;
}

AgentsFeed .agent-detail {
    height: 1;
    padding: 0 1;
    background: $primary 5%;
}

/* Footer */
Footer {
    height: auto;
}

/* ========================================================= */
/* AI Ask panel                                               */
/* ========================================================= */

AskPanel {
    height: 2;
}

AskPanel.--has-response {
    height: 16;
}

AskPanel .ask-rule {
    height: 1;
    padding: 0 1;
    color: $text-muted;
}

AskPanel #ask-rule-top {
    height: 0;
    overflow: hidden;
}

AskPanel.--has-response #ask-rule-top {
    height: 1;
}

AskPanel #ask-prompt-row {
    height: 1;
}

AskPanel #ask-prompt-arrow {
    width: 3;
    height: 1;
    padding: 0 0 0 1;
    color: $primary;
}

AskPanel #ask-input {
    width: 1fr;
    height: 1;
    border: none;
    background: $surface;
    padding: 0;
    scrollbar-size: 0 0;
}

AskPanel #ask-input:focus {
    border: none;
}

AskPanel #ask-input .text-area--cursor-line {
    background: $surface;
}

AskPanel #ask-input .text-area--cursor {
    background: $primary;
    color: $surface;
}

AskPanel #ask-response-container {
    height: 1fr;
    padding: 0 1;
    display: none;
}

AskPanel.--has-response #ask-response-container {
    display: block;
    align: left bottom;
}

AskPanel #ask-response {
    height: auto;
    padding: 0;
}

AskPanel #ask-status {
    height: 1;
    padding: 0 1;
    display: none;
}

AskPanel.--has-response #ask-status {
    display: block;
}

/* ========================================================= */
/* Shared styles for pushed screens                           */
/* ========================================================= */

.panel {
    height: 1fr;
    padding: 1;
}

.step {
    border: solid $primary;
    padding: 1;
}

.step-hovered {
    border: solid $primary;
}

.step-highlight {
    border: solid $primary;
}

.card {
    width: 1fr;
    height: 100%;
    border: solid $primary;
    padding: 1;
    background: $surface;
}

/* Pagination bar (centered, with top padding for breathing room) */
PaginationBar {
    height: 3;
    content-align: center middle;
    padding: 1 1 0 1;
}

ListView {
    & > ListItem {
        &.-highlight {
            background: $panel 40%;
        }
    }
}

/* Tree hover: distinct teal so it doesn't blend with green selection */
Tree > .tree--cursor {
    background: $primary 20%;
}

Tree > .tree--hover {
    background: $panel 40%;
}

/* TrajectoryScreen */
TrajectoryScreen {
    layout: vertical;
}

#trajectory-summary {
    height: auto;
    max-height: 3;
    padding: 0 1;
}

DecisionMinimap {
    height: 1;
    padding: 0 1;
    margin: 0 0 1 0;
}

#trajectory-content {
    height: 1fr;
}

#step-list {
    width: 0.4fr;
    min-width: 30;
    height: 100%;
    border: round $secondary-background-darken-3;
}

#step-list:focus {
    border: round $primary;
}

#step-detail {
    width: 0.6fr;
    height: 100%;
    padding: 0 1;
    border: round $secondary-background-darken-3;
}

#step-detail:focus {
    border: round $primary;
}

.step-row {
    height: 1;
    padding: 0 1;
}

.step-gap {
    height: 1;
    padding: 0 1;
}

.step-row--selected {
    background: $primary 12%;
}

.step-row--denied {
    background: $error 6%;
}

.step-row--denied.step-row--selected {
    background: $error 15%;
}

.step-row.--search-match {
    background: $primary 20%;
}

.step-row.--search-match.step-row--selected {
    background: $primary 30%;
}

/* Decision-colored step borders (right margin for scrollbar clearance) */
.step-allow {
    border: solid $secondary-background-darken-3;
    border-title-color: $foreground;
    border-subtitle-color: $text-muted;
    border-subtitle-align: right;
    padding: 0 1;
    margin: 0 1 0 0;
}

.step-deny {
    border: solid $error;
    border-title-color: $foreground;
    border-subtitle-color: $text-muted;
    border-subtitle-align: right;
    padding: 0 1;
    margin: 0 1 0 0;
}

.step-escalate {
    border: solid $warning;
    border-title-color: $foreground;
    border-subtitle-color: $text-muted;
    border-subtitle-align: right;
    padding: 0 1;
    margin: 0 1 0 0;
}

.step-prompt {
    border: solid $prompt-blue;
    border-title-color: $foreground;
    border-subtitle-color: $text-muted;
    border-subtitle-align: right;
    padding: 0 1;
    margin: 0 1 0 0;
}

.step-prompt-model {
    border: solid $model-muted;
    border-title-color: $foreground;
    border-subtitle-color: $text-muted;
    border-subtitle-align: right;
    padding: 0 1;
    margin: 0 1 0 0;
}

/* Search (trajectory screen) */
#search-status {
    height: 1;
    padding: 0 1;
    background: $surface;
}

#search-input {
    height: 1;
    background: $surface;
    color: $primary;
    padding: 0 1;
    border: none;
}

#search-input:focus {
    border: none;
}

/* AgentScreen */
AgentScreen {
    layout: vertical;
}

AgentScreen #agent-summary {
    height: auto;
    padding: 0 1;
}

AgentScreen TrajectoryFeed {
    height: 1fr;
}

AgentScreen TrajectoryFeed #trajectories-container {
    height: 1fr;
    max-height: 100%;
}

AgentScreen PaginationBar {
    height: 2;
    padding: 0 1;
}


/* ToolCard */
ToolCard {
    border: solid $secondary;
    height: auto;
    padding: 1;
    margin-bottom: 1;
}

.tool-card-content {
    height: auto;
}

.tool-description {
    padding-bottom: 1;
}

.tool-parameters {
    color: $text-muted;
}

.tool-response {
    color: $text-muted;
}

